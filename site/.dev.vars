# Local development only. This file is COMMITTED, so never put a secret in it.
# Real secrets belong in `wrangler secret put`, which never touches the repo.
#
# Why this exists: `wrangler dev` reports request.url as the custom domain
# (http://contextbenchmark.com/) while actually serving plain http on localhost.
# The Worker's http -> https canonical redirect would therefore point at itself
# and loop forever in dev. Turning canonicalisation off locally keeps
# `wrangler dev` usable.
#
# Production never reads this file, so the redirects stay on where they matter.
# Covered by site/test/canonical.test.mjs, which asserts both polarities.
CANONICALISE = "off"
