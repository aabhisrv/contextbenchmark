{
  "name": "contextbenchmark",
  "version": "0.1.0",
  "description": "The open benchmark for measuring the reliability, reproducibility, and determinism of AI context systems. Compare context engines with transparent metrics, reproducible tests, and vendor-neutral results.",
  "type": "module",
  "bin": {
    "contextbenchmark": "./contextbenchmark.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bench": "node contextbenchmark.mjs run --adapters bm25",
    "bench:all": "node contextbenchmark.mjs run --adapters bm25,emb-minilm,spiderbrain",
    "test:site": "node --test \"site/test/*.test.mjs\""
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "keywords": [
    "determinism",
    "reproducibility",
    "benchmark",
    "rag",
    "retrieval",
    "agent-memory",
    "context-engineering"
  ],
  "license": "MIT",
  "homepage": "https://contextbenchmark.com"
}
